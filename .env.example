# ── Supabase ──────────────────────────────────────────────────────────────────
# Pega estos valores desde: Supabase → Settings → API

# Usada en el FRONTEND (Next.js) y en el script Python
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...    # segura para exponer en frontend (RLS la protege)

# Usada SOLO en el script Python — NUNCA la pongas en el frontend
SUPABASE_SERVICE_ROLE_KEY=eyJ...        # bypasea RLS, mantenerla secreta
